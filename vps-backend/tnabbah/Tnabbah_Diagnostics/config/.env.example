# Copy to config/.env and fill in real values (never commit config/.env).

# --- API server ---
# FASTAPI_HOST=0.0.0.0
# FASTAPI_PORT=8001
# DEBUG=false

# --- CORS (comma-separated origins; use * to allow all) ---
# ALLOWED_ORIGINS=

# --- Optional admin / debug ---
# DEBUG_MODE=false
# ADMIN_TOKEN=

# --- Data path override (prefer TNABBAH_DATA_PATH; AI_ENGINE_DATA_PATH still works) ---
# TNABBAH_DATA_PATH=
# AI_ENGINE_DATA_PATH=

# --- DeepSeek AI Configuration ---
# DEEPSEEK_API_KEY=sk-...        # Required; get from platform.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat   # Default model (deepseek-chat, deepseek-coder, deepseek-reasoner)
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1  # API endpoint

# --- AI Performance Tuning ---
# TNABBAH_ENABLE_AI=true       # Set to false to disable AI entirely (instant responses)
# TNABBAH_AI_FAST=false        # Set to true for faster AI (reduced tokens, ~50% faster)
# TNABBAH_AI_TIMEOUT=15        # API timeout in seconds (default: 15)
# TNABBAH_AI_ALWAYS_EXPLAIN=false  # Set to true to explain ALL PIDs even when healthy (slower)
